@baseUrl = http://localhost:8080
@conversationId = conv-001

### Health Check
GET {{baseUrl}}/v1/api/health

### Message Save - TEXT
POST {{baseUrl}}/v1/api/conversations/{{conversationId}}/messages
Content-Type: application/json

{
  "messageId": "msg-001",
  "senderId": "user-a",
  "messageType": "TEXT",
  "content": "hello redis caching gateway",
  "metadataJson": null,
  "sentAt": "2026-03-15T11:40:00"
}

### Message Save - IMAGE
POST {{baseUrl}}/v1/api/conversations/{{conversationId}}/messages
Content-Type: application/json

{
  "messageId": "msg-002",
  "senderId": "user-b",
  "messageType": "IMAGE",
  "content": null,
  "metadataJson": "{\"url\":\"https://example.com/sample-image.jpg\",\"fileName\":\"sample-image.jpg\"}",
  "sentAt": "2026-03-15T11:41:00"
}

### Message Save - FILE
POST {{baseUrl}}/v1/api/conversations/{{conversationId}}/messages
Content-Type: application/json

{
  "messageId": "msg-003",
  "senderId": "user-a",
  "messageType": "FILE",
  "content": null,
  "metadataJson": "{\"url\":\"https://example.com/manual.pdf\",\"fileName\":\"manual.pdf\",\"size\":123456}",
  "sentAt": "2026-03-15T11:42:00"
}

### Message Save - SYSTEM
POST {{baseUrl}}/v1/api/conversations/{{conversationId}}/messages
Content-Type: application/json

{
  "messageId": "msg-004",
  "senderId": "system",
  "messageType": "SYSTEM",
  "content": "user-b joined the conversation",
  "metadataJson": null,
  "sentAt": "2026-03-15T11:43:00"
}

### Get Recent Messages
GET {{baseUrl}}/v1/api/conversations/{{conversationId}}/messages?limit=50

### Get Messages Before
GET {{baseUrl}}/v1/api/conversations/{{conversationId}}/messages?before=2026-03-15T11:42:00&limit=20

### Get Messages After
GET {{baseUrl}}/v1/api/conversations/{{conversationId}}/messages?after=2026-03-15T11:40:00&limit=20

### Get Conversation Meta
GET {{baseUrl}}/v1/api/conversations/{{conversationId}}/meta

### Get Not Found Conversation Meta
GET {{baseUrl}}/v1/api/conversations/not-found/meta